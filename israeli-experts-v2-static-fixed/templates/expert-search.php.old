<?php
/*
Template Name: חיפוש מאגר
Author: pablo rotem
*/

get_header();

$lang = 'HEB';
global $wpdb;
global $idUniq;

$idUniq = 0;
$disabledCats = [3, 4, 5, 6, 191, 253, 288, 814, 815];

/**
 * בניית עץ קטגוריות רקורסיבי
 * Author: pablo rotem
 */
function build_wp_category_tree($parentCatId, $isOpen = false): string
{
    global $wpdb, $idUniq, $disabledCats, $lang;

    $parentCatId = (int) $parentCatId;

    $sql = "
        SELECT t1.id, t2.name
        FROM categories t1
        LEFT JOIN categories_byLang t2
            ON t1.id = t2.categoryId
        WHERE t2.language = %s
          AND t1.type = 'specific'
          AND t1.parentId = %d
        ORDER BY t1.pos ASC
    ";

    $results = $wpdb->get_results(
        $wpdb->prepare($sql, (string) $lang, $parentCatId),
        ARRAY_A
    );

    if (!$results) {
        return '';
    }

    $html = '';
    if ($isOpen) {
        $html .= '<ul class="DefineTree treeplant line-tree">';
    } else {
        $currId = ++$idUniq;
        $html .= '<ul id="collapse' . $currId . '" class="panel-collapse collapse line-tree">';
    }

    foreach ($results as $row) {
        $catId = (int) $row['id'];
        $catName = (string) $row['name'];

        $currId = ++$idUniq;
        $sons = build_wp_category_tree($catId, false);
        $hasSons = ($sons !== '');

        $toggleHtml = $hasSons
            ? '<a data-toggle="collapse" href="#collapse' . ($currId + 1) . '" class="insExtra collapsed"></a>'
            : '<span class="insExtraSpacer"></span>';

        if (in_array($catId, $disabledCats, true)) {
            $link = 'javascript:void(0);';
            $clickAttr = '';
            $itemClass = 'root-category';
        } else {
            $link = 'javascript:void(0);';
            $clickAttr = 'onclick="mygetvaluetodicv(\'' . esc_js($catName) . '\', ' . $catId . ')"';
            $itemClass = 'clickable-category paratext';
        }

        $html .= '<li>';
        $html .= $toggleHtml;
        $html .= '<a href="' . $link . '" ' . $clickAttr . ' class="' . esc_attr($itemClass) . '">' . esc_html($catName) . '</a>';
        $html .= $sons;
        $html .= '</li>';
    }

    $html .= '</ul>';

    return $html;
}

// 3. SEARCH PROCESSING - לוגיקה קרובה לפלאגין הניהול
// Author: pablo rotem

$results = [];
$has_searched = false;
$cnt = 0;

$nameText = isset($_REQUEST['nameText']) ? trim((string) wp_unslash($_REQUEST['nameText'])) : '';
$profText = isset($_REQUEST['profText']) ? trim((string) wp_unslash($_REQUEST['profText'])) : '';
$freeText = isset($_REQUEST['freeText']) ? trim((string) wp_unslash($_REQUEST['freeText'])) : '';
$dialZone = isset($_REQUEST['dialZone']) ? trim((string) wp_unslash($_REQUEST['dialZone'])) : '';
$catIdRaw = isset($_REQUEST['catId']) ? trim((string) wp_unslash($_REQUEST['catId'])) : '';

$catId = (ctype_digit($catIdRaw) && (int) $catIdRaw > 0) ? (int) $catIdRaw : 0;

if (
    $_SERVER['REQUEST_METHOD'] === 'POST'
    || $catId > 0
    || $nameText !== ''
    || $profText !== ''
    || $freeText !== ''
    || $dialZone !== ''
) {
    $has_searched = true;

    $where = [];
    $params = [];

    $baseSql = "
        FROM clubMembers m
        LEFT JOIN israeli_experts e
            ON e.memberId = m.id
        WHERE m.status = %s
          AND m.extraData4 = %s
          AND e.memberLanguage = %s
    ";

    $baseParams = ['active', 'expert', $lang];

    /**
     * לפי שם
     * Author: pablo rotem
     */
    if ($nameText !== '') {
        $like = '%' . $wpdb->esc_like($nameText) . '%';
        $where[] = "
            (
                CONCAT(COALESCE(m.lastname,''), ' ', COALESCE(m.firstname,'')) LIKE %s
                OR CONCAT(COALESCE(m.firstname,''), ' ', COALESCE(m.lastname,'')) LIKE %s
            )
        ";
        $params[] = $like;
        $params[] = $like;
    }

    /**
     * לפי מקצוע
     * Author: pablo rotem
     */
    if ($profText !== '') {
        $like = '%' . $wpdb->esc_like($profText) . '%';
        $where[] = "
            (
                e.fldProfession LIKE %s
                OR e.fldSpecialization LIKE %s
                OR e.moreDetails LIKE %s
            )
        ";
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
    }

    /**
     * לפי ביטוי
     * Author: pablo rotem
     */
    if ($freeText !== '') {
        $like = '%' . $wpdb->esc_like($freeText) . '%';
        $where[] = "
            (
                m.firstname LIKE %s
                OR m.lastname LIKE %s
                OR m.email LIKE %s
                OR m.phone LIKE %s
                OR m.cellphone LIKE %s
                OR e.fldProfession LIKE %s
                OR e.fldSpecialization LIKE %s
                OR e.moreDetails LIKE %s
            )
        ";
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
        $params[] = $like;
    }

    /**
     * לפי אזור חיוג - זהה לפלאגין
     * Author: pablo rotem
     */
    if ($dialZone !== '' && preg_match('/^(02|03|04|08|09)$/', $dialZone)) {
        $where[] = " e.fldDialZone = %s ";
        $params[] = $dialZone;
    }

    $extraWhere = '';
    if (!empty($where)) {
        $extraWhere = ' AND ' . implode(' AND ', $where);
    }

    /**
     * אם נבחרה קטגוריה - כולל עץ תתי קטגוריות
     * Author: pablo rotem
     */
    if ($catId > 0) {
        $sql = "
            WITH RECURSIVE cat_tree AS (
                SELECT id
                FROM categories
                WHERE id = %d

                UNION ALL

                SELECT c.id
                FROM categories c
                INNER JOIN cat_tree t
                    ON c.parentId = t.id
                WHERE c.type = 'specific'
            )
            SELECT DISTINCT m.*, e.*
            $baseSql
            AND EXISTS (
                SELECT 1
                FROM categoriesItems ci
                INNER JOIN cat_tree ct
                    ON ct.id = ci.categoryId
                WHERE ci.itemId = m.id
            )
            $extraWhere
            ORDER BY CAST(COALESCE(m.extraData6, 0) AS UNSIGNED) DESC, BINARY m.lastname
        ";

        $allParams = array_merge([$catId], $baseParams, $params);
        $prepared = $wpdb->prepare($sql, ...$allParams);
    } else {
        $sql = "
            SELECT DISTINCT m.*, e.*
            $baseSql
            $extraWhere
            ORDER BY CAST(COALESCE(m.extraData6, 0) AS UNSIGNED) DESC, BINARY m.lastname
        ";

        $allParams = array_merge($baseParams, $params);
        $prepared = $wpdb->prepare($sql, ...$allParams);
    }

    $results = $wpdb->get_results($prepared, ARRAY_A);
    $cnt = is_array($results) ? count($results) : 0;
}
?>

