<script>
/* Author: pablo rotem */
function mygetvaluetodicv(name, id) {
    var catInput = document.getElementById('catIdInput');
    var display  = document.getElementById('searchExpertyDisplay');
    var form     = document.getElementById('searchExp');

    if (catInput) {
        catInput.value = id;
    }

    if (display) {
        display.innerHTML = name;
    }

    if (form) {
        form.submit();
    }
}

document.addEventListener('DOMContentLoaded', function () {
    var form = document.getElementById('searchExp');
    var button = document.getElementById('repositorySearchButton');
    var catInput = document.getElementById('catIdInput');
    var display = document.getElementById('searchExpertyDisplay');

    if (!form || !button || !catInput) {
        return;
    }

    button.addEventListener('click', function () {
        catInput.value = '';

        if (display) {
            display.innerHTML = 'לפי התמחות';
        }
    });
});
</script>

